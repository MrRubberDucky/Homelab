{
    admin unix//run/admin.sock
    auto_https disable_redirects
    order coraza_waf first
    order crowdsec after coraza_waf
    order appsec after crowdsec
    order defender before basic_auth
    order rate_limit after defender
    crowdsec {
        api_url <snip>
        api_key {$CROWDSEC_API_KEY}
        ticker_interval 30s
        appsec_url http://crowdsec:7422
    }
    log default {
        output stdout
        level INFO
        format json
    }
    acme_ca https://acme-v02.api.letsencrypt.org/directory
    email {$ACME_EMAIL}
    servers {
        listener_wrappers {
            proxy_protocol {
                    timeout 5s
                    allow vps_ipv4 vps_ipv6 127.0.0.1/8
                    fallback_policy reject
                }
                http_redirect
                tls
            }
        trusted_proxies combine {
            static vps_ipv4 vps_ipv6 private_ranges
        }
        trusted_proxies_strict
    }
}
