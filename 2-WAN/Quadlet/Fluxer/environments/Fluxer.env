# /srv/fluxer/.env
# Quadlet can't handle multiple environment expansions? Not sure.
# So you'll need to expand and match similar variables yourself.
NODE_ENV=production
FLUXER_ENV=production
FLUXER_DOMAIN=chat.yourdomain.tld
FLUXER_BASE_DOMAIN=chat.yourdomain.tld
FLUXER_PUBLIC_SCHEME=https
FLUXER_PUBLIC_PORT=443
FLUXER_CADDY_SITE_ADDRESS=:8777
# Trust reverse proxy
FLUXER_TRUST_CLIENT_IP_HEADER=true
FLUXER_CLIENT_IP_HEADER_NAME=x-forwarded-for

# Notifications (vapid)
FLUXER_VAPID_PUBLIC_KEY=https://docs.fluxer.app/operator/get-started/
FLUXER_VAPID_PRIVATE_KEY=https://docs.fluxer.app/operator/get-started/
FLUXER_VAPID_EMAIL=admin@yourdomain.tld

# Secrets
FLUXER_S3_ACCESS_KEY=fluxer
FLUXER_S3_SECRET_KEY=openssl rand -hex 32
FLUXER_SUDO_MODE_SECRET=openssl rand -hex 32
FLUXER_CONNECTION_INITIATION_SECRET=openssl rand -hex 32
FLUXER_GATEWAY_RPC_AUTH_TOKEN=openssl rand -hex 32
FLUXER_MEDIA_PROXY_SECRET_KEY=openssl rand -hex 32
FLUXER_ADMIN_SECRET_KEY_BASE=openssl rand -hex 32
FLUXER_ADMIN_OAUTH_CLIENT_SECRET=openssl rand -hex 32
FLUXER_MEDIA_PROXY_UPLOAD_RELAY_SECRET_BASE64=openssl rand -base64 32

# S3
FLUXER_S3_ENDPOINT=http://fluxer-seaweedfs:8333
FLUXER_S3_PUBLIC_ENDPOINT=http://fluxer-seaweedfs:8333
FLUXER_S3_ACCESS_KEY_ID=fluxer
FLUXER_S3_SECRET_ACCESS_KEY=openssl rand -hex 32
# Change this to whatever you like
FLUXER_S3_REGION=pl-waw-1
FLUXER_S3_FORCE_PATH_STYLE=true
FLUXER_S3_BUCKET_CDN=fluxer
FLUXER_S3_BUCKET_UPLOADS=fluxer-uploads
FLUXER_S3_BUCKET_DOWNLOADS=fluxer-downloads
FLUXER_S3_BUCKET_REPORTS=fluxer-reports
FLUXER_S3_BUCKET_HARVESTS=fluxer-harvests
# We don't use AWS but this was configured like this in docker-compose.yaml
# Needs to match FLUXER_S3_ACCESS_KEY_ID
AWS_ACCESS_KEY_ID=XXXX
# Needs to match FLUXER_S3_SECRET_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=XXXX
# Needs to match FLUXER_S3_REGION
AWS_DEFAULT_REGION=pl-waw-1
AWS_EC2_METADATA_DISABLED=true

# Endpoints
FLUXER_INTERNAL_API_ENDPOINT=http://fluxer-api:8080
FLUXER_INTERNAL_GATEWAY_ENDPOINT=http://fluxer-gateway:8080
FLUXER_INTERNAL_MEDIA_PROXY_ENDPOINT=http://fluxer-media-proxy:8080
FLUXER_MARKETING_ENDPOINT=https://chat.yourdomain.tld
FLUXER_MEDIA_PROXY_ENDPOINT=http://fluxer-media-proxy:8080
FLUXER_MEDIA_ENDPOINT=https://chat.yourdomain.tld/media
FLUXER_MEDIA_PROXY_UPLOAD_RELAY_ENDPOINT=https://chat.yourdomain.tld/media

# Valkey + Nats configuration
FLUXER_KV_URL=redis://fluxer-valkey:6379/0
FLUXER_NATS_URL=nats://fluxer-nats:4222
FLUXER_NATS_JETSTREAM_URL=nats://fluxer-nats:4222
FLUXER_SVC_NATS_URL=nats://fluxer-nats:4222
FLUXER_SVC_SHARD_COUNT=1

# Database + Meilisearch settings
FLUXER_DATABASE_BACKEND=postgres
FLUXER_POSTGRES_HOST=fluxer-postgres
FLUXER_POSTGRES_PORT=5432
# Needs to match POSTGRES_USER and POSTGRES_PASSWORD
FLUXER_POSTGRES_USERNAME=XXXX
FLUXER_POSTGRES_PASSWORD=XXXX
FLUXER_POSTGRES_SSL=false
FLUXER_SEARCH_ENGINE=meilisearch
FLUXER_SEARCH_URL=http://fluxer-meilisearch:7700
# Needs to match MEILI_ACCESS_KEY
FLUXER_SEARCH_API_KEY=XXXX

# LiveKit settings
FLUXER_LIVEKIT_ENABLED=true

# Tell Fluxer that this is self-hosted
FLUXER_SELF_HOSTED=true
FLUXER_DISCOVERY_ENABLED=true

# Rest - These can be reconfigured in admin dashboard and during first setup
# Cloudflare (Turnstile) Captcha
FLUXER_CAPTCHA_ENABLED=false
FLUXER_CAPTCHA_PROVIDER=none
FLUXER_CAPTCHA_ENABLED=false
FLUXER_GIF_PROVIDER=klipy
FLUXER_EMAIL_ENABLED=false
FLUXER_SMS_ENABLED=false
FLUXER_STRIPE_ENABLED=false
FLUXER_NCMEC_ENABLED=false
#FLUXER_CLAMAV_ENABLED=false
#FLUXER_CLAMAV_HOST=
#FLUXER_CLAMAV_PORT=
FLUXER_EMAIL_ENABLED=false
FLUXER_EMAIL_PROVIDER=none
FLUXER_EMAIL_FROM_EMAIL=noreply@example.com
FLUXER_EMAIL_FROM_NAME=Fluxer
FLUXER_EMAIL_SMTP_HOST=
FLUXER_EMAIL_SMTP_PORT=587
FLUXER_EMAIL_SMTP_USERNAME=
FLUXER_EMAIL_SMTP_PASSWORD=
FLUXER_EMAIL_SMTP_SECURE=true
