ND_PASSWORDENCRYPTIONKEY=my_example_password_encryption_key
ND_SESSION_TIMEOUT=96h
ND_ADDRESS=unix:/run/tmp/navidrome.sock
ND_BASEURL=https://music.localhost.domain.tld
ND_SHAREURL=https://music.localhost.domain.tld
ND_ENABLEINSIGHTSCOLLECTOR=false
ND_AUTHREQUESTLIMIT=3
ND_AUTHWINDOWLENGTH=30s
ND_AUTOIMPORTPLAYLISTS=false
ND_BACKUP_COUNT=3
ND_DEFAULTDOWNSAMPLINGFORMAT=mp3
ND_DEFAULTLANGUAGE=pl
ND_DEFAULTTHEME=dark
ND_DEFAULTSHAREEXPIRATION=720h
ND_DEFAULTVOLUME=50
ND_ENABLEREPLAYGAIN=true
ND_ENABLESHARING=true
ND_UIWELCOMEMESSAGE=Example Description
ND_UNIXSOCKETPERM=750
ND_DEFAULTUIVOLUME=50
ND_ENABLEEXTERNALSERVICES=true
ND_ENABLESHARING=true
ND_ENABLETRANSCODINGCANCELLATION=true
ND_ENABLEUSEREDITING=true
ND_EXTAUTH_TRUSTEDSOURCES=@
