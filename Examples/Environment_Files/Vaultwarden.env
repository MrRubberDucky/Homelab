# UDS connection to Postgres, mount Postgres socket to /var/run/postgresql
DATABASE_URL=postgres://username:password@/database_name?sslmode=disable&host=/var/run/postgresql
# Create & set ProxyAuth on VoidAuth to vault.localhost.domain.tld/admin*
DISABLE_ADMIN_TOKEN=true
PUSH_INSTALLATION_ID=my_push_id
PUSH_INSTALLATION_KEY=my_push_key
ORG_CREATION_USERS=email@domain.tld
PASSWORD_ITERATIONS=my_password_iterations
# VW - Global Settings
ENABLE_WEBSOCKET=true
PUSH_ENABLED=true
PUSH_RELAY_URI=https://api.bitwarden.eu
PUSH_IDENTITY_URI=https://identity.bitwarden.eu
# VW - General Settings
DOMAIN=https://vault.localhost.domain.tld
SENDS_ALLOWED=true
TRASH_AUTO_DELETE_DAYS=90
INCOMPLETE_2FA_TIME_LIMIT=3
SIGNUPS_ALLOWED=false
SIGNUPS_VERIFY=true
INVITATIONS_ORG_NAME=my_org_name
EMERGENCY_ACCESS_ALLOWED=true
EMAIL_CHANGE_ALLOWED=false
# Disallow hints
PASSWORD_HINTS_ALLOWED=false
SHOW_PASSWORD_HINTS=false
EROCKET_ADDRESS=0.0.0.0
ROCKET_PORT=8000
ICON_SERVICE=internal
DISABLE_ICON_DOWNLOAD=false
TEMPLATES_FOLDER=/data/templates
EXPERIMENTAL_CLIENT_FEATURE_FLAGS=autofill-overlay,autofill-v2,fido2-vault-credentials,inline-menu-positioning-improvements,ssh-key-vault-item,ssh-agent
# Bug with VW container sometimes thinking its on temp storage
I_REALLY_WANT_VOLATILE_STORAGE=true
# SSO
SSO_ENABLED=true
SSO_ONLY=false
SSO_AUTH_ONLY_NOT_SESSION=false
SSO_AUTHORITY=https://auth.localhost.domain.tld/oidc
SSO_SCOPES="openid profile email offline_access"
SSO_CLIENT_ID=client_id_from_voidauth
SSO_CLIENT_SECRET=client_secret_from_voidauth
