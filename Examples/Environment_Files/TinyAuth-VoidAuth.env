TINYAUTH_APPURL=https://auth-gateway.localhost.domain.tld
TINYAUTH_ANALYTICS_ENABLED=false
TINYAUTH_SECURE_COOKIE=true
TINYAUTH_OAUTH_PROVIDERS_GENERIC_CLIENTID=CLIENT_FROM_VOIDAUTH
TINYAUTH_OAUTH_PROVIDERS_GENERIC_CLIENTSECRET=CLIENT_SECRET_FROM_VOIDAUTH
TINYAUTH_OAUTH_PROVIDERS_GENERIC_SCOPES=openid profile email groups
TINYAUTH_OAUTH_PROVIDERS_GENERIC_REDIRECTURL=https://auth-gateway.localhost.domain.tld/api/oauth/callback/generic
TINYAUTH_OAUTH_PROVIDERS_GENERIC_AUTHURL=https://auth.localhost.domain.tld/oidc/auth
TINYAUTH_OAUTH_PROVIDERS_GENERIC_TOKENURL=https://auth.localhost.domain.tld/oidc/token
TINYAUTH_OAUTH_PROVIDERS_GENERIC_USERINFOURL=https://auth.localhost.domain.tld/oidc/me
TINYAUTH_OAUTH_PROVIDERS_GENERIC_NAME=providerName
TINYAUTH_APPS_SYNCTHING_OAUTH_GROUPS=administrators
TINYAUTH_APPS_SYNCTHING_IP_ALLOW=10.0.0.0/8
TINYAUTH_APPS_SYNCTHING_OAUTH_WHITELIST=user@domain.tld
TINYAUTH_APPS_SYNCTHING_CONFIG_DOMAIN=sync.localhost.domain.tld
TINYAUTH_APPS_SYNCTHING_RESPONSE_BASICAUTH_USERNAME=basic_username
TINYAUTH_APPS_SYNCTHING_RESPONSE_BASICAUTH_PASSWORD=basic_password
TINYAUTH_OAUTH_AUTOREDIRECT=generic
TINYAUTH_SERVER_SOCKETPATH=/run/tmp/tinyauth.sock
