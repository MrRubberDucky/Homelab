APP_URL=https://auth.localhost.domain.tld
APP_PORT=/run/tmp/voidauth.sock
SIGNUP_REQUIRES_APPROVAL=true
EMAIL_VERIFICATION=false
MFA_REQUIRED=true
PASSWORD_STRENGTH=3
APP_TITLE=MyProvider
APP_COLOR="#5b21b6"
CONTACT_EMAIL=user@domain.tld
STORAGE_KEY=read_documentation
STORAGE_KEY_SECONDARY=read_documentation
DB_USER=postgres_user
DB_PASSWORD=postgres_password
DB_HOST=/var/run/postgres
DB_NAME=voidauth
