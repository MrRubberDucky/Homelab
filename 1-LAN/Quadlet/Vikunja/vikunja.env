VIKUNJA_SERVICE_PUBLICURL=https://todo.localhost.domain.tld/
VIKUNJA_SERVICE_SECRET=
VIKUNJA_DATABASE_HOST=/var/run/postgresql
VIKUNJA_DATABASE_USER=
VIKUNJA_DATABASE_PASSWORD=
VIKUNJA_DATABASE_TYPE=postgres
VIKUNJA_DATABASE_DATABASE=vikunja
VIKUNJA_AUTH_LOCAL_ENABLED=false
VIKUNJA_AUTH_OPENID_ENABLED=true
VIKUNJA_AUTH_OPENID_PROVIDERS_MYPROVIDER_NAME=
VIKUNJA_AUTH_OPENID_PROVIDERS_MYPROVIDER_AUTHURL=https://auth.localhost.domain.tld/oidc
VIKUNJA_AUTH_OPENID_PROVIDERS_MYPROVIDER_CLIENTID=
VIKUNJA_AUTH_OPENID_PROVIDERS_MYPROVIDER_CLIENTSECRET=
VIKUNJA_AUTH_OPENID_PROVIDERS_MYPROVIDER_SCOPE=openid profile email
VIKUNJA_AUTH_OPENID_PROVIDERS_MYPROVIDER_FORCEUSERINFO=false
