# ~/Environments/Homarr/.proxy
SP_ALLOW_GET=(/_ping|/info|/version|/events|/containers/json|/containers/[^/]+/(json|stats))$
SP_ALLOWFROM=homarr
SP_ALLOWHEALTHCHECK=yes
SP_STOPONWATCHDOG=yes
SP_WATCHDOGINTERVAL=10
SP_SHUTDOWNGRACETIME=10
SP_PROXYSOCKETENDPOINT=/run/tmp/podman.sock
SP_PROXYSOCKETENDPOINTFILEMODE=0007
