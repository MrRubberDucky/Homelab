# ~/Environments/Homarr/.env
DOCKER_HOST=unix:///run/tmp/podman.sock
BASE_URL=dash.localhost.domain.tld
SECRET_ENCRYPTION_KEY=read_documentation
AUTH_PROVIDERS=oidc
AUTH_OIDC_ISSUER=read_documentation
AUTH_OIDC_CLIENT_ID=read_documentation
AUTH_OIDC_CLIENT_SECRET=read_documentation
AUTH_OIDC_CLIENT_NAME=read_documentation
AUTH_OIDC_AUTO_LOGIN=true
AUTH_LOGOUT_REDIRECT_URL=read_documentation
# Needed for proper DNAT loopback, otherwise nextjs will use internal DNS to query DNS -> domain resolves to LAN IP -> ECONNREFUSED
ENABLE_DNS_CACHING=false
